# Скопируй в .env рядом с docker-compose.yml и заполни.

# Секрет для подписи JWT — длинная случайная строка.
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# Стартовый суперадмин (создаётся только если БД пустая)
ADMIN_EMAIL=admin@koordinatorstvo2026.ru
ADMIN_PASSWORD=change-me-strong
ADMIN_NAME=Суперадмин
